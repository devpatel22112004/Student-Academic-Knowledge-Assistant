# ===== ENVIRONMENT CONFIGURATION =====
# Copy this file to .env and fill in your actual credentials
# Keep .env file private - never commit it to Git!

# ===== GEMINI API Configuration =====
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===== PINECONE VECTOR DATABASE =====
# Get credentials from: https://www.pinecone.io/
# Your Pinecone API Key
PINECONE_API_KEY=your_pinecone_api_key_here

# Your Pinecone Host URL (from Pinecone dashboard)
PINECONE_HOST=https://your-index-name-xxx.svc.aped-xxxx-xxxx.pinecone.io

# Your Pinecone Index name
PINECONE_INDEX_NAME=student-assistant
